{
  "name": "homecareops-api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test:unit": "find src -name '*.test.js' -type f | sort | xargs node --test",
    "test:cleanup": "node src/scripts/dropTestDatabase.js",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "search:cleanup": "node src/scripts/searchCleanup.js",
    "retention:cleanup": "node src/scripts/retentionCleanup.js"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  }
}
